# ──────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env.vps y rellena TODOS los valores antes de ejecutar
#   cp env.vps.example .env.vps
#   nano .env.vps
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de datos (PostgreSQL interno en Docker) ──────────────────────────────
POSTGRES_USER=calculodb
POSTGRES_PASSWORD=cambia_esta_contrasena_db
POSTGRES_DB=calculodb

# ── Sesiones (OBLIGATORIO en producción) ─────────────────────────────────────
# Genera uno con:   openssl rand -hex 64
SESSION_SECRET=

# ── Puerto interno donde escucha el contenedor web ────────────────────────────
# Apache hará proxy hacia 127.0.0.1:WEB_PORT
# Cambia el puerto si ya está en uso por otro proyecto (ej. 4200 → Spelling Bee)
WEB_PORT=4201
